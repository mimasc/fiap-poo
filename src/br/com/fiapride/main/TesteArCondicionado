import br.com.fiapride.model.ArCondicionado;

public class TesteArCondicionado {

    public static void main(String[] args) {
        // Criando o objeto do Ar-condicionado
        ArCondicionado meuAr = new ArCondicionado();
        meuAr.marca = "Samsung";
        meuAr.temperaturaDesejada = 20; // Definindo um valor inicial base
        
        // 1. Ligando o ar com o método True/False que você pediu
        meuAr.LigarDesligar(true);
        
        // 2. Em vez de setTemperatura(22), vamos subir de 20 para 22:
        meuAr.adicionarTemperatura(); // Vai para 21
        meuAr.adicionarTemperatura(); // Vai para 22
        
        // 3. Exemplo: Se quiser baixar para 21 novamente:
        meuAr.diminuirTemperatura();
        
        // 4. Desligando o ar
        meuAr.LigarDesligar(false);
        
        // Mostrando o resultado final no console
        System.out.println("--- Status Final ---");
        System.out.println("Marca: " + meuAr.marca);
        System.out.println("Temperatura Final: " + meuAr.temperaturaDesejada + "°C");
        System.out.println("Está ligado? " + meuAr.ligado);
    }
}

